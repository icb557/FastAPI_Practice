# Notetaker API – Environment Variables Template
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to version control.

# ============================================
# Database Configuration
# ============================================

# PostgreSQL database name
POSTGRES_DB=notetaker

# PostgreSQL database user
POSTGRES_USER=notetaker

# PostgreSQL database password
# IMPORTANT: Use a strong password in production
POSTGRES_PASSWORD=your_secure_password_here

# ============================================
# API Connection to Database
# ============================================

# Host — use 'db' when running inside Docker Compose, 'localhost' for local dev
POSTGRES_HOST=db

# Port
POSTGRES_PORT=5432

# ============================================
# Application Configuration
# ============================================

# Application display name
APP_NAME=Notetaker API

# Debug mode — set to true for development, false for production
DEBUG=true
